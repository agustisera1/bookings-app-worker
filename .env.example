# Copiar a .env y reemplazar los valores reales (passwords, API keys).

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=CHANGE_ME
PGDATABASE=bookings

# MongoDB
MONGODB_URI=mongodb://localhost:27017

# Redis (cola BullMQ + adapter de socket.io)
REDIS_URL=redis://worker:CHANGE_ME@localhost:6379

# Resend (emails)
RESEND_API_KEY=re_...

# Emails
# DEV_MODE=1 redirige todos los emails a DEV_EMAIL_TO y usa el sender sandbox.
DEV_MODE=1
EMAIL_FROM=onboarding@resend.dev
DEV_EMAIL_TO=agustisera1@gmail.com

# Socket.io chat server
SOCKET_PORT=4000
CLIENT_ORIGIN=http://localhost:3000
